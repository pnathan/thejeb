{
  "variables": [
    {
      "name": "primary_cause",
      "domain": ["moon", "sun_and_moon", "earth_motion"],
      "description": "The fundamental agent(s) the author identifies as the cause of the tides."
    },
    {
      "name": "moon_role",
      "domain": ["attraction", "pressure", "rejected"],
      "description": "The kind of causal role, if any, attributed specifically to the moon's action on the waters: it draws/attracts them, it presses on them via an intervening medium, or its causal role is explicitly denied."
    },
    {
      "name": "mechanism",
      "domain": ["direct_correspondence", "gravitational_attraction", "basin_motion", "pressure_of_vortex", "dynamical_oscillation"],
      "description": "The physical (or pre-physical) process by which the primary cause is held to produce the rise and fall of the waters."
    },
    {
      "name": "sun_role",
      "domain": ["reinforces_at_syzygy", "weaker_than_moon"],
      "description": "How the sun's contribution to the tides is characterized relative to the moon's."
    },
    {
      "name": "spring_neap_dependence",
      "domain": ["springs_at_syzygy", "neaps_at_quadrature"],
      "description": "Whether tidal range is tied to the alignment of moon and sun, i.e. greatest at new/full moon (syzygy) or least at the half moon (quadrature)."
    },
    {
      "name": "earth_motion_required",
      "domain": ["required"],
      "description": "Whether the theory holds that the Earth's own motion (rotation and/or revolution) is a necessary cause of the tides."
    },
    {
      "name": "quantitative",
      "domain": ["mathematized"],
      "description": "Whether the account gives a mathematically predictive treatment of tidal heights and times, rather than a purely qualitative description."
    }
  ],
  "synonyms": {
