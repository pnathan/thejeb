{
  "variables": [
    {
      "name": "ratification_stance",
      "domain": [
        "supports_ratification",
        "opposes_ratification",
        "supports_with_prior_amendments"
      ],
      "description": "The document's overall position on whether the proposed Constitution should be ratified as written, rejected, or ratified only after prior amendment."
    },
    {
      "name": "union_vs_disunion",
      "domain": [
        "single_union_essential",
        "separate_confederacies_preferable"
      ],
      "description": "Whether the thirteen states should remain one union under a single general government, or whether dissolving into separate regional confederacies is preferable or acceptable."
    },
    {
      "name": "government_character",
      "domain": [
        "federal_confederacy",
        "national_consolidated",
        "mixed_composite"
      ],
      "description": "How the proposed government is classified: as a federal league of sovereign states, a national/consolidated government over individuals, or a mixed/composite of both."
    },
    {
      "name": "federal_power_scope",
      "domain": [
        "extensive_indefinite_necessary",
        "strictly_limited_enumerated"
      ],
      "description": "Whether the national government should hold broad, indefinite powers (taxation, defense, commerce) adequate to unforeseeable needs, or whether its powers should be tightly confined to specific enumerated objects, leaving the residue to the states."
    },
    {
      "name": "standing_army_restriction",
      "domain": [
        "discretion_sufficient",
        "restriction_required"
      ],
      "description": "Whether leaving peacetime military establishments to legislative discretion (with safeguards like the two-year appropriations limit) is sufficient, or whether the Constitution should explicitly restrict/prohibit standing armies."
    },
    {
      "name": "executive_structure",
      "domain": [
        "single_executive_beneficial",
        "requires_council_or_plurality"
      ],
      "description": "Whether vesting executive power in a single magistrate is safer and more energetic, versus the view that executive power should be checked by a plural executive or an executive council."
    },
    {
      "name": "senate_equal_suffrage",
      "domain": [
        "justified_compromise",
        "unjust_violates_majority_rule"
      ],
      "description": "Whether equal state representation in the Senate (regardless of population) is a necessary and legitimate protection of state sovereignty, or an unjust violation of proportional/majority representation."
    },
    {
      "name": "judicial_power",
      "domain": [
        "safe_essential_check",
        "dangerous_excessive"
      ],
      "description": "Whether an independent judiciary with life tenure and (implied) power to void unconstitutional acts is a safe and essential check on the other branches, or a dangerously unaccountable concentration of power."
    },
    {
      "name": "bill_of_rights_necessity",
      "domain": [
        "unnecessary_or_dangerous",
        "necessary_safeguard"
      ],
      "description": "Whether a separate, explicit bill of rights is unnecessary or even dangerous (because it implies powers not granted), or whether its absence is a serious defect requiring one."
    },
    {
      "name": "extended_republic_theory",
      "domain": [
        "extended_republic_superior",
        "small_republic_safer"
      ],
      "description": "Whether an extended, populous republic (like the proposed Union) better controls the effects of faction and preserves liberty than a small republic, or whether traditional theory (small, homogeneous territory) is safer for republican government."
    }
  ],
